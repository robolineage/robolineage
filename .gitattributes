# 所有文本文件统一使用 LF
* text=auto eol=lf

# 明确标记为文本的格式
*.py      text eol=lf
*.ts      text eol=lf
*.vue     text eol=lf
*.js      text eol=lf
*.css     text eol=lf
*.scss    text eol=lf
*.html    text eol=lf
*.md      text eol=lf
*.txt     text eol=lf
