# Normalize text files to LF.
* text=auto eol=lf

# Explicit text formats.
*.py      text eol=lf
*.ts      text eol=lf
*.vue     text eol=lf
*.js      text eol=lf
*.css     text eol=lf
*.scss    text eol=lf
*.html    text eol=lf
*.md      text eol=lf
*.txt     text eol=lf
*.rst     text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.toml    text eol=lf
*.json    text eol=lf
*.jsonl   text eol=lf
*.csv     text eol=lf
*.sh      text eol=lf
*.ini     text eol=lf
*.cfg     text eol=lf
*.xml     text eol=lf
*.svg     text eol=lf
*.pyi     text eol=lf
*.pyx     text eol=lf
*.pxd     text eol=lf

# Keep Windows scripts as CRLF.
*.ps1     text eol=crlf
*.bat     text eol=crlf
*.cmd     text eol=crlf

# Binary files should not be line-ending normalized.
*.h5      binary
*.hdf5    binary
*.npy     binary
*.npz     binary
*.pkl     binary
*.pth     binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.mp4     binary
*.avi     binary
*.mov     binary
*.pdf     binary
*.pptx    binary
*.gz      binary
*.zip     binary
*.tar     binary
*.so      binary
*.dylib   binary
*.exe     binary
*.pem     binary
*.fits    binary
*.pyc     binary
