# RoboLineage .env template. Copy to .env or /etc/robolineage/.env and fill in.
#
# NEVER commit a real .env. The repo's .gitignore already excludes it.
# On the robot workstation, load via systemd `EnvironmentFile=/etc/robolineage/.env` (chmod 600).
# In dev mode, python-dotenv picks up a local .env automatically.
#
# Default production path here is an OpenAI-compatible gateway that routes
# model id `anthropic/claude-sonnet-4.6`. Keep per-agent MODEL lines explicit
# so each agent can be moved to a different model later without code edits.

# Robot Onboarding LLM: robot profile, topic, and binding understanding.
ROBOT_ONBOARDING_LLM_API_KEY=REPLACE_WITH_API_KEY
ROBOT_ONBOARDING_LLM_BASE_URL=https://your-gateway.example.com/v1
ROBOT_ONBOARDING_LLM_MODEL=anthropic/claude-sonnet-4.6

# Task Config LLM: task description and scene image to task_config.
TASK_LLM_BACKEND=openai
TASK_LLM_API_KEY=REPLACE_WITH_API_KEY
TASK_LLM_BASE_URL=https://your-gateway.example.com/v1
TASK_LLM_MODEL=anthropic/claude-sonnet-4.6

# Online Visual Snapshot Agent VLM: runs during rollout collection.
VSA_VLM_BACKEND=openai
VSA_VLM_API_KEY=REPLACE_WITH_API_KEY
VSA_VLM_BASE_URL=https://your-gateway.example.com/v1
VSA_VLM_MODEL=anthropic/claude-sonnet-4.6
VSA_VLM_MAX_TOKENS=512

# Post-Rollout Review VLM: asynchronous review after a rollout closes.
POST_REVIEW_VLM_BACKEND=openai
POST_REVIEW_VLM_API_KEY=REPLACE_WITH_API_KEY
POST_REVIEW_VLM_BASE_URL=https://your-gateway.example.com/v1
POST_REVIEW_VLM_MODEL=anthropic/claude-sonnet-4.6
POST_REVIEW_VLM_MAX_TOKENS=512

# Framework Discovery LLM: training repository and command understanding.
ROBOLINEAGE_DISCOVERY_LLM_API_KEY=REPLACE_WITH_API_KEY
ROBOLINEAGE_DISCOVERY_LLM_BASE_URL=https://your-gateway.example.com/v1
ROBOLINEAGE_DISCOVERY_LLM_MODEL=anthropic/claude-sonnet-4.6

# Training Monitor LLM: training logs, anomalies, and convergence summaries.
TRAINING_MONITOR_LLM_API_KEY=REPLACE_WITH_API_KEY
TRAINING_MONITOR_LLM_BASE_URL=https://your-gateway.example.com/v1
TRAINING_MONITOR_LLM_MODEL=anthropic/claude-sonnet-4.6

# Policy Evaluation VLM: visual review after evaluation rollouts close.
POLICY_EVAL_VLM_BACKEND=openai
POLICY_EVAL_VLM_API_KEY=REPLACE_WITH_API_KEY
POLICY_EVAL_VLM_BASE_URL=https://your-gateway.example.com/v1
POLICY_EVAL_VLM_MODEL=anthropic/claude-sonnet-4.6
POLICY_EVAL_VLM_MAX_TOKENS=512

# Deployment Governance LLM: multi-rollout deployment recommendation summaries.
DEPLOYMENT_GOVERNANCE_LLM_API_KEY=REPLACE_WITH_API_KEY
DEPLOYMENT_GOVERNANCE_LLM_BASE_URL=https://your-gateway.example.com/v1
DEPLOYMENT_GOVERNANCE_LLM_MODEL=anthropic/claude-sonnet-4.6

# Dataset Health LLM: coverage, failure distribution, and recollection guidance.
DATASET_HEALTH_LLM_API_KEY=REPLACE_WITH_API_KEY
DATASET_HEALTH_LLM_BASE_URL=https://your-gateway.example.com/v1
DATASET_HEALTH_LLM_MODEL=anthropic/claude-sonnet-4.6

# Master Agent LLM: cross-iteration lifecycle memory and next-action summaries.
MASTER_LLM_API_KEY=REPLACE_WITH_API_KEY
MASTER_LLM_BASE_URL=https://your-gateway.example.com/v1
MASTER_LLM_MODEL=anthropic/claude-sonnet-4.6

# Shared fallback for OpenAI-compatible routes.
# OPENAI_API_KEY=REPLACE_WITH_API_KEY
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=anthropic/claude-sonnet-4.6

# ROS2.
# ROS_DOMAIN_ID=0
