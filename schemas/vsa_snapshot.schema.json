{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robolineage.github.io/schemas/vsa_snapshot.schema.json",
  "title": "Visual snapshot artifact",
  "type": "object",
  "required": ["artifact_id", "artifact_type", "schema_version", "created_at", "producer", "parents", "content_hash", "content"],
  "properties": {
    "artifact_id": { "type": "string" },
    "artifact_type": { "const": "vsa_snapshot" },
    "schema_version": { "type": "string" },
    "created_at": { "type": "string" },
    "producer": { "type": "string" },
    "parents": { "type": "array", "items": { "type": "string" } },
    "content_hash": { "type": "string" },
    "content": {
      "type": "object",
      "required": ["rollout_id", "time_range", "phase", "evidence"],
      "properties": {
        "rollout_id": { "type": "string" },
        "time_range": {
          "type": "object",
          "required": ["start_sec", "end_sec"],
          "properties": {
            "start_sec": { "type": "number" },
            "end_sec": { "type": "number" }
          }
        },
        "phase": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence": { "type": "array", "items": { "type": "string" } },
        "uncertainty": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
