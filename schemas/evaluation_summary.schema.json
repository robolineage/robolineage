{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robolineage.github.io/schemas/evaluation_summary.schema.json",
  "title": "Evaluation summary artifact",
  "type": "object",
  "required": ["artifact_id", "artifact_type", "schema_version", "created_at", "producer", "parents", "content_hash", "content"],
  "properties": {
    "artifact_id": { "type": "string" },
    "artifact_type": { "const": "evaluation_summary" },
    "schema_version": { "type": "string" },
    "created_at": { "type": "string" },
    "producer": { "type": "string" },
    "parents": { "type": "array", "items": { "type": "string" } },
    "content_hash": { "type": "string" },
    "content": {
      "type": "object",
      "required": ["policy_id", "task_name", "trial_count", "success_count"],
      "properties": {
        "policy_id": { "type": "string" },
        "task_name": { "type": "string" },
        "trial_count": { "type": "integer", "minimum": 1 },
        "success_count": { "type": "integer", "minimum": 0 },
        "failure_phases": { "type": "object" },
        "regressions": { "type": "array", "items": { "type": "string" } },
        "representative_rollouts": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
