{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robolineage.github.io/schemas/dataset_lock.schema.json",
  "title": "Dataset lock artifact",
  "type": "object",
  "required": ["artifact_id", "artifact_type", "schema_version", "created_at", "producer", "parents", "content_hash", "content"],
  "properties": {
    "artifact_id": { "type": "string" },
    "artifact_type": { "const": "dataset_lock" },
    "schema_version": { "type": "string" },
    "created_at": { "type": "string" },
    "producer": { "type": "string" },
    "parents": { "type": "array", "items": { "type": "string" } },
    "content_hash": { "type": "string" },
    "content": {
      "type": "object",
      "required": ["dataset_id", "accepted_rollouts", "adapter_profile"],
      "properties": {
        "dataset_id": { "type": "string" },
        "accepted_rollouts": { "type": "array", "items": { "type": "string" } },
        "failure_pool": { "type": "array", "items": { "type": "string" } },
        "adapter_profile": { "type": "string" },
        "split_policy": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
