{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robolineage.github.io/schemas/robot_profile.schema.json",
  "title": "Robot profile artifact",
  "type": "object",
  "required": ["artifact_id", "artifact_type", "schema_version", "created_at", "producer", "parents", "content_hash", "content"],
  "properties": {
    "artifact_id": { "type": "string" },
    "artifact_type": { "const": "robot_profile" },
    "schema_version": { "type": "string" },
    "created_at": { "type": "string" },
    "producer": { "type": "string" },
    "parents": { "type": "array", "items": { "type": "string" } },
    "content_hash": { "type": "string" },
    "content": {
      "type": "object",
      "required": ["robot_name", "embodiment", "streams"],
      "properties": {
        "robot_name": { "type": "string" },
        "embodiment": { "type": "string" },
        "workspace": { "type": "string" },
        "streams": {
          "type": "object",
          "required": ["primary_camera", "robot_state", "action_command"],
          "properties": {
            "primary_camera": { "type": "string" },
            "wrist_camera": { "type": "string" },
            "robot_state": { "type": "string" },
            "action_command": { "type": "string" },
            "episode_clock": { "type": "string" }
          },
          "additionalProperties": { "type": "string" }
        },
        "operator_notes": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
