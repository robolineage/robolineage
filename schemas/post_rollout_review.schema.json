{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robolineage.github.io/schemas/post_rollout_review.schema.json",
  "title": "Post-rollout review artifact",
  "type": "object",
  "required": ["artifact_id", "artifact_type", "schema_version", "created_at", "producer", "parents", "content_hash", "content"],
  "properties": {
    "artifact_id": { "type": "string" },
    "artifact_type": { "const": "post_rollout_review" },
    "schema_version": { "type": "string" },
    "created_at": { "type": "string" },
    "producer": { "type": "string" },
    "parents": { "type": "array", "items": { "type": "string" } },
    "content_hash": { "type": "string" },
    "content": {
      "type": "object",
      "required": ["rollout_id", "outcome", "admission_recommendation", "evidence"],
      "properties": {
        "rollout_id": { "type": "string" },
        "outcome": { "enum": ["success", "failure", "uncertain"] },
        "primary_failure_phase": { "type": "string" },
        "admission_recommendation": { "enum": ["accept", "needs_review", "failure_pool", "exclude"] },
        "evidence": { "type": "array", "items": { "type": "string" } },
        "terminal_observation": { "type": "string" },
        "risk_flags": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
