{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robolineage.github.io/schemas/training_run.schema.json",
  "title": "Training run artifact",
  "type": "object",
  "required": ["artifact_id", "artifact_type", "schema_version", "created_at", "producer", "parents", "content_hash", "content"],
  "properties": {
    "artifact_id": { "type": "string" },
    "artifact_type": { "const": "training_run" },
    "schema_version": { "type": "string" },
    "created_at": { "type": "string" },
    "producer": { "type": "string" },
    "parents": { "type": "array", "items": { "type": "string" } },
    "content_hash": { "type": "string" },
    "content": {
      "type": "object",
      "required": ["run_id", "dataset_lock_id", "framework", "command"],
      "properties": {
        "run_id": { "type": "string" },
        "dataset_lock_id": { "type": "string" },
        "framework": { "type": "string" },
        "command": { "type": "string" },
        "code_revision": { "type": "string" },
        "output_policy_id": { "type": "string" },
        "metrics": { "type": "object" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
