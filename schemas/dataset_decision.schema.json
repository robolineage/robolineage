{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robolineage.github.io/schemas/dataset_decision.schema.json",
  "title": "Dataset decision artifact",
  "type": "object",
  "required": ["artifact_id", "artifact_type", "schema_version", "created_at", "producer", "parents", "content_hash", "content"],
  "properties": {
    "artifact_id": { "type": "string" },
    "artifact_type": { "const": "dataset_decision" },
    "schema_version": { "type": "string" },
    "created_at": { "type": "string" },
    "producer": { "type": "string" },
    "parents": { "type": "array", "items": { "type": "string" } },
    "content_hash": { "type": "string" },
    "content": {
      "type": "object",
      "required": ["rollout_id", "training_eligibility", "route", "reason"],
      "properties": {
        "rollout_id": { "type": "string" },
        "training_eligibility": { "type": "boolean" },
        "route": { "enum": ["primary_training", "human_review", "failure_pool", "excluded"] },
        "reason": { "type": "string" },
        "override": { "type": "object" },
        "split": { "enum": ["train", "validation", "test", "none"] }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
