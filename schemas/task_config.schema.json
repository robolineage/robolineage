{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robolineage.github.io/schemas/task_config.schema.json",
  "title": "Task configuration artifact",
  "type": "object",
  "required": ["artifact_id", "artifact_type", "schema_version", "created_at", "producer", "parents", "content_hash", "content"],
  "properties": {
    "artifact_id": { "type": "string" },
    "artifact_type": { "const": "task_config" },
    "schema_version": { "type": "string" },
    "created_at": { "type": "string" },
    "producer": { "type": "string" },
    "parents": { "type": "array", "items": { "type": "string" } },
    "content_hash": { "type": "string" },
    "content": {
      "type": "object",
      "required": ["task_name", "goal", "phases", "success_criteria"],
      "properties": {
        "task_name": { "type": "string" },
        "goal": { "type": "string" },
        "phases": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "success_criteria": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "failure_modes": { "type": "array", "items": { "type": "string" } },
        "risk_events": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
