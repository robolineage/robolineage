{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://RoboLineage.local/schemas/training_status.schema.json",
  "title": "RoboLineage Framework Training Status",
  "type": "object",
  "required": ["schema_version", "status", "framework", "dataset_version", "policy_version", "updated_at"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {"type": "string"},
    "status": {"enum": ["running", "completed", "failed", "unstable"]},
    "framework": {"type": "string"},
    "dataset_version": {"type": "string"},
    "policy_version": {"type": "string"},
    "selected_rollout_count": {"type": "integer", "minimum": 0},
    "checkpoint_path": {"oneOf": [{"type": "null"}, {"type": "string"}]},
    "current_command": {"type": "string"},
    "current_log_path": {"type": "string"},
    "failed_command": {
      "oneOf": [
        {"type": "string"},
        {"type": "array", "items": {"type": "string"}}
      ]
    },
    "returncode": {"type": "integer"},
    "metrics": {"type": "object"},
    "updated_at": {"type": "string"}
  }
}
