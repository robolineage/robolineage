{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://RoboLineage.local/schemas/training_result.schema.json",
  "title": "RoboLineage Framework Training Result",
  "type": "object",
  "required": ["schema_version", "framework", "framework_type", "dataset_version", "policy_version", "training_result_path", "selected_rollout_count", "created_at"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {"type": "string"},
    "framework": {"type": "string"},
    "framework_type": {"type": "string"},
    "adapter_version": {"type": "string"},
    "dataset_version": {"type": "string"},
    "policy_version": {"type": "string"},
    "staging_dir": {"type": "string"},
    "selected_rollouts_file": {"type": "string"},
    "selected_rollouts_dir": {"oneOf": [{"type": "null"}, {"type": "string"}]},
    "framework_input_dir": {"oneOf": [{"type": "null"}, {"type": "string"}]},
    "dataset_output_dir": {"type": "string"},
    "checkpoint_dir": {"type": "string"},
    "checkpoint_path": {"oneOf": [{"type": "null"}, {"type": "string"}]},
    "eval_output_dir": {"oneOf": [{"type": "null"}, {"type": "string"}]},
    "training_status_path": {"oneOf": [{"type": "null"}, {"type": "string"}]},
    "training_result_path": {"type": "string"},
    "eval_result_path": {"oneOf": [{"type": "null"}, {"type": "string"}]},
    "commands": {"type": "array", "items": {"type": "object"}},
    "selected_rollout_count": {"type": "integer", "minimum": 0},
    "created_at": {"type": "string"}
  }
}
