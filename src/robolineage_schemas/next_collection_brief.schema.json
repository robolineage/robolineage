{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://RoboLineage.local/schemas/next_collection_brief.schema.json",
  "title": "RoboLineage Next Collection Brief",
  "type": "object",
  "required": ["schema_version", "agent_version", "source_decision", "recommended_mode", "target_count", "focus_phases", "focus_failure_modes", "operator_brief", "success_criteria", "created_at"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {"type": "string"},
    "agent_version": {"type": "string"},
    "session_id": {"oneOf": [{"type": "null"}, {"type": "string"}]},
    "policy_version": {"oneOf": [{"type": "null"}, {"type": "string"}]},
    "source_decision": {"type": "string"},
    "recommended_mode": {"type": "string"},
    "target_count": {"type": "integer", "minimum": 0},
    "focus_phases": {"type": "array", "items": {"type": "string"}},
    "focus_failure_modes": {"type": "array", "items": {"type": "string"}},
    "scene_variations": {"type": "array", "items": {"type": "string"}},
    "operator_brief": {"type": "string", "minLength": 1},
    "success_criteria": {"type": "string", "minLength": 1},
    "created_at": {"type": "string"}
  }
}
